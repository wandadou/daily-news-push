# ============================================
# 🚀 必填配置（两个都要填才能跑）
# ============================================

# ① 飞书群机器人 Webhook URL
# 去哪里拿：飞书群 → 群设置 → 群机器人 → 添加机器人 → 自定义机器人
# 复制机器人的 Webhook 地址贴到下面引号里
# 示例: export FEISHU_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/abcd1234-5678-xxxx-xxxx-xxxxxxxxxxxx"
export FEISHU_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/1ed71070-2d0b-48bc-b40e-70090a0c7cc6"

# ② DeepSeek API Key
# 去哪里拿：https://platform.deepseek.com/api_keys 注册 → 创建 API Key
# 复制 Key 贴到下面引号里（以 sk- 开头）
# 示例: export DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export DEEPSEEK_API_KEY="sk-341d8d12d48a4e3fa9bd70a49b15da80"


# ============================================
# 🔧 可选配置（不改也能用）
# ============================================

# DeepSeek 模型（deepseek-chat 是默认模型，一般无需修改）
# export DEEPSEEK_MODEL="deepseek-chat"

# 如果想用 DALL-E 自动配图（需要额外买 OpenAI 的 API Key），取消下面两行的注释并填 Key
# export OPENAI_API_KEY="sk-你的OpenAI_API_Key"
# export OPENAI_IMAGE_MODEL="dall-e-3"
